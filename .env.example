# ─────────────────────────────────────────────────────────────────────────────
# NHS RTT & CWT ELT Pipeline — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCTIONS:
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value in your .env file
# 3. Never commit .env to version control — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ─── Google Cloud Platform ────────────────────────────────────────────────────
# Path to your GCP service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/keyfile.json

# Your GCP project ID (found in GCP Console → Project Info)
GCP_PROJECT_ID=your-gcp-project-id

# BigQuery dataset where raw NHS data will be landed
GCP_RAW_DATASET=nhs_rtt_raw

# BigQuery dataset where dbt transformed models will live
GCP_DBT_DATASET=nhs_rtt_dbt

# GCS bucket for storing raw CSV files before BigQuery load
GCP_BUCKET_NAME=your-gcp-bucket-name

# GCP region — use europe-west2 for UK data residency compliance
GCP_REGION=europe-west2

# ─── Apache Airflow ───────────────────────────────────────────────────────────
# User ID for Airflow process inside Docker (run: id -u in terminal)
AIRFLOW_UID=50000

# Fernet key for encrypting Airflow connection passwords
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here

# Airflow environment — controls logging verbosity and behaviour
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true

# Airflow webserver admin credentials — change before any deployment
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change-me-before-deployment

# ─── dbt ──────────────────────────────────────────────────────────────────────
# dbt target environment — options: dev, staging, prod
DBT_TARGET=dev

# dbt threads — how many models run in parallel
DBT_THREADS=4

# ─── NHS Data Sources ─────────────────────────────────────────────────────────
# Base URL for NHS England statistical releases
NHS_RTT_BASE_URL=https://www.england.nhs.uk/statistics/statistical-work-areas/rtt-waiting-times/
NHS_CWT_BASE_URL=https://www.england.nhs.uk/statistics/statistical-work-areas/cancer-waiting-times/

# ─── Pipeline Config ──────────────────────────────────────────────────────────
# How many months of historical RTT data to load on first run
HISTORICAL_LOAD_MONTHS=24

# Email for pipeline failure alerts
ALERT_EMAIL=your-email@example.com